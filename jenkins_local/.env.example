# Jenkins Agent Configuration
# Get these values after adding a node in Jenkins UI:
#   Jenkins → Manage Jenkins → Nodes → New Node
JENKINS_URL=https://your-server.com:9090
JENKINS_AGENT_NAME=mac-builder
JENKINS_AGENT_SECRET=<paste-secret-from-jenkins-ui-after-adding-node>
JENKINS_AGENT_WORKDIR=/Users/your-user/jenkins-agent

# Connection mode: 'direct' (port 50000, faster) or 'websocket' (through reverse proxy, slower)
# Use 'direct' if port 50000 is accessible from this Mac to the Jenkins server
JENKINS_AGENT_MODE=direct

# Unity editors location (auto-detected from this path)
UNITY_EDITORS_PATH=/Applications/Unity/Hub/Editor
